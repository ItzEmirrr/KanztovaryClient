# Скопируй этот файл в deploy/.env и заполни значения
# cp deploy/.env.example deploy/.env

# ─── База данных ──────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRATION=86400000

# ─── Anthropic AI (для /api/v1/recommendations) ───────────────────────────────
ANTHROPIC_API_KEY=

# ─── Настройки заказов ────────────────────────────────────────────────────────
ORDER_DELIVERY_FEE=0
ORDER_FREE_DELIVERY_THRESHOLD=10000
KPI_LOW_STOCK_THRESHOLD=5
